<odoo>
    <record id='group_kitchen_staff' model='res.groups'>
        <field name='name'>Kitchen Staff</field>
    </record>
    <record id='group_ngo' model='res.groups'>
        <field name='name'>NGO Users</field>
    </record>

    <record id='food_batch_rule_own' model='ir.rule'>
        <field name='name'>Kitchen staff: own batches only</field>
        <field name='model_id' ref='model_food_batch'/>
        <field name='domain_force'>[('create_uid','=',user.id)]</field>
        <field name='groups' eval='[(4, ref("group_kitchen_staff"))]' />
    </record>

    <record id='pickup_rule_own' model='ir.rule'>
        <field name='name'>NGOs: own pickups only</field>
        <field name='model_id' ref='model_pickup_request'/>
        <field name='domain_force'>[('receiver_id.user_id','=',user.id)]</field>
        <field name='groups' eval='[(4, ref("group_ngo"))]' />
    </record>
</odoo>
