<odoo>
    <record id="cron_expiry_cleanup" model="ir.cron">
        <field name="name">Remove expired food batches</field>
        <field name="model_id" ref="model_food_batch"/>
        <field name="state">code</field>
        <field name="code">model.unlink_expired_batches()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>
