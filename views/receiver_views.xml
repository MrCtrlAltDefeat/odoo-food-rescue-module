<odoo>
    <record id="view_receiver_list" model="ir.ui.view">
        <field name="name">receiver.list</field>
        <field name="model">receiver</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="contact"/>
                <field name="pickup_capacity"/>
            </list>
        </field>
    </record>

    <record id="view_receiver_form" model="ir.ui.view">
        <field name="name">receiver.form</field>
        <field name="model">receiver</field>
        <field name="arch" type="xml">
            <form string="Receiver">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="contact"/>
                        <field name="pickup_capacity"/>
                        <field name="user_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivers" model="ir.actions.act_window">
        <field name="name">Receivers</field>
        <field name="res_model">receiver</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
