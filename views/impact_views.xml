<odoo>
    <record id="view_impact_list" model="ir.ui.view">
        <field name="name">impact_log.list</field>
        <field name="model">impact_log</field>
        <field name="arch" type="xml">
            <list>
                <field name="pickup_id"/>
                <field name="meals_saved"/>
                <field name="kg_waste_avoided"/>
                <field name="co2_saved"/>
            </list>
        </field>
    </record>

    <record id="view_impact_form" model="ir.ui.view">
        <field name="name">impact_log.form</field>
        <field name="model">impact_log</field>
        <field name="arch" type="xml">
            <form string="Impact Log">
                <sheet>
                    <group>
                        <field name="pickup_id"/>
                        <field name="meals_saved"/>
                        <field name="kg_waste_avoided"/>
                        <field name="co2_saved"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_impact_logs" model="ir.actions.act_window">
        <field name="name">Impact Logs</field>
        <field name="res_model">impact_log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
