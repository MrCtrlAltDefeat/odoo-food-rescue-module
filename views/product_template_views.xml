<odoo>
  <record id="view_product_form_leftover" model="ir.ui.view">
    <field name="name">product.template.form.leftover.food</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//page[@name='sales']" position="inside">
        <group string="Leftover Food">
          <field name="is_leftover"/>
          <field name="food_type" invisible="not is_leftover"/>
          <group invisible="not is_leftover">
            <field name="leftover_qty"/>
            <field name="leftover_qty_unit"/>
          </group>
          <div class="o_form_label" invisible="not is_leftover">
            Set Sales Price to 0.00 and Publish on Website.
          </div>
        </group>
      </xpath>
    </field>
  </record>
</odoo>