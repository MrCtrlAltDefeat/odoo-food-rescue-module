<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- === Window Actions === -->
    <record id="action_food_batches" model="ir.actions.act_window">
        <field name="name">Food Batches</field>
        <field name="res_model">food_batch</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_receivers" model="ir.actions.act_window">
        <field name="name">Receivers</field>
        <field name="res_model">receiver</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_pickups" model="ir.actions.act_window">
        <field name="name">Pickups</field>
        <field name="res_model">pickup_request</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_impact_logs" model="ir.actions.act_window">
        <field name="name">Impact Logs</field>
        <field name="res_model">impact_log</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- === Menus === -->
    <menuitem id="menu_food_root" name="Food Waste to Food Plate" sequence="10"/>

    <menuitem id="menu_food_batches" name="Food Batches" parent="menu_food_root" sequence="10" action="action_food_batches"/>
    <menuitem id="menu_receivers" name="Receivers" parent="menu_food_root" sequence="20" action="action_receivers"/>
    <menuitem id="menu_pickups" name="Pickups" parent="menu_food_root" sequence="30" action="action_pickups"/>
    <menuitem id="menu_impact_logs" name="Impact Logs" parent="menu_food_root" sequence="40" action="action_impact_logs"/>
</odoo>
